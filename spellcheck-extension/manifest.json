{
  "manifest_version": 3,
  "name": "Corrector Facebook (LanguageTool)",
  "version": "1.0.0",
  "description": "Sugerencias ortográficas en Facebook usando LanguageTool.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://facebook.com/*",
    "https://m.facebook.com/*",
    "https://www.instagram.com/*",
    "https://instagram.com/*",
    "https://api.languagetool.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Corrector Facebook",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/*",
        "https://facebook.com/*",
        "https://m.facebook.com/*",
        "https://www.instagram.com/*",
        "https://instagram.com/*"
      ],
      "js": ["utils/spellcheck.js", "content.js"],
      "css": ["css/theme-vars.css", "styles.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
